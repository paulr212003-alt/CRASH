NODE_ENV=development
HOST=0.0.0.0
PORT=5000

# Local MongoDB example:
# MONGO_URI=mongodb://127.0.0.1:27017/visitorDB

# MongoDB Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/visitorDB?retryWrites=true&w=majority&appName=<cluster-name>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/visitorDB?retryWrites=true&w=majority&appName=<cluster-name>

# IMPORTANT: change in production
ADMIN_PASSWORD=admin123

# Comma-separated list. Leave empty to allow all origins.
# Example:
# CORS_ORIGINS=https://rico-visitor.onrender.com,https://portal.company.com
CORS_ORIGINS=

# Optional approval email workflow
APPROVAL_EMAIL_TO=paul.r212003@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password-or-app-password>
SMTP_FROM=RICO Visitor Portal <your-email@example.com>
